# Environment Configuration
NODE_ENV=production

# Server
PORT=3000
HOST=0.0.0.0

# CORS
CORS_ORIGIN=*

# Redis
REDIS_URL=redis://redis:6379

# Database (PostgreSQL)
DATABASE_URL=postgresql://grading_user:secure_password@postgres:5432/grading_db

# Cache
CACHE_TTL=60000
MAX_CACHE_SIZE=10000

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=1000

# Logging
LOG_LEVEL=info

# Security
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production

# Instance info
INSTANCE=app-1
