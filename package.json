{
  "name": "grading-calculator",
  "version": "2.0.0",
  "description": "Fast, responsive, and scalable grading calculator supporting millions of concurrent users",
  "main": "server/index.js",
  "scripts": {
    "start": "node server/index.js",
    "dev": "NODE_ENV=development nodemon server/index.js",
    "prod": "NODE_ENV=production node server/index.js",
    "cluster": "NODE_ENV=production node server/index.js",
    "test": "echo \"Error: no test specified\" && exit 1",
    "lint": "eslint .",
    "build": "echo 'No build needed for this project'",
    "prepare-www": "node scripts/copy-public.js",
    "icons:generate": "node scripts/generate-icons.js",
    "cap:init": "npx cap init grading-calculator com.example.gradingcalculator --web-dir=www",
    "cap:add-android": "npx cap add android",
    "cap:add-ios": "npx cap add ios",
    "cap:copy": "npx cap copy",
    "cap:open-android": "npx cap open android",
    "cap:open-ios": "npx cap open ios"
  },
  "keywords": [
    "grading",
    "gpa",
    "calculator",
    "responsive",
    "scalable"
  ],
  "author": "Your Name",
  "license": "MIT",
  "dependencies": {
    "@capacitor/android": "^5.7.8",
    "@capacitor/core": "^5.0.0",
    "compression": "^1.7.4",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-rate-limit": "^7.1.5",
    "helmet": "^7.1.0"
  },
  "devDependencies": {
    "@capacitor/cli": "^5.0.0",
    "eslint": "^8.51.0",
    "nodemon": "^3.0.1",
    "sharp": "^0.32.0"
  },
  "capacitor": {
    "webDir": "www",
    "appId": "com.example.gradingcalculator",
    "appName": "grading-calculator"
  },
  "engines": {
    "node": ">=16.0.0"
  }
}
